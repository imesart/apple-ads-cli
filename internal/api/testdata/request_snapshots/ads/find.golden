POST https://api.searchads.apple.com/api/v5/campaigns/12345/adgroups/67890/ads/find
Accept: application/json
Authorization: Bearer token
Content-Type: application/json
Host: api.searchads.apple.com
X-AP-Context: orgId=12345

{
  "conditions": [
    {
      "field": "status",
      "operator": "EQUALS",
      "values": [
        "ENABLED"
      ]
    },
    {
      "field": "deleted",
      "operator": "IN",
      "values": [
        true,
        false
      ]
    }
  ],
  "fields": [
    "id",
    "name"
  ],
  "orderBy": [
    {
      "field": "creationTime",
      "sortOrder": "ASCENDING"
    }
  ],
  "pagination": {
    "limit": 20,
    "offset": 40
  }
}
